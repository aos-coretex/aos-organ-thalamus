    "GitSync:status": { "organ_url_key": "gitsyncUrl",    "method": "GET",  "path": "/status",           "body_template": null },
    "Promote:status": { "organ_url_key": "promoteUrl",    "method": "GET",  "path": "/status",           "body_template": null },
    "Lobe:query":     { "organ_url_key": "lobeUrl",        "method": "POST", "path": "/query",            "body_template": { "query": "$.description" } }
  }
