{
  "$documentation": "R0 action -> HTTP endpoint mapping. Used by lib/r0-dispatcher.js to translate AP targets (organ:action format) into concrete HTTP calls. Every action listed in config/action-classifier.json as 'r0' should have a corresponding entry here. Missing entries cause r0_action_not_implemented errors at dispatch time.",
  "$last_synced": "2026-04-12",
  "actions": {
    "Radiant:query":  { "organ_url_key": "radiantUrl",     "method": "POST", "path": "/query",            "body_template": { "query": "$.description" } },
    "Radiant:read":   { "organ_url_key": "radiantUrl",     "method": "GET",  "path": "/blocks/$.urn",     "body_template": null },
    "Minder:query":   { "organ_url_key": "minderUrl",      "method": "POST", "path": "/query",            "body_template": { "query": "$.description" } },
    "Minder:get_card":{ "organ_url_key": "minderUrl",      "method": "GET",  "path": "/cards/$.urn",      "body_template": null },
    "Minder:get_representation": { "organ_url_key": "minderUrl", "method": "GET", "path": "/representations/$.urn", "body_template": null },
    "Hippocampus:query":   { "organ_url_key": "hippocampusUrl", "method": "POST", "path": "/query",       "body_template": { "query": "$.description" } },
    "Hippocampus:get_session": { "organ_url_key": "hippocampusUrl", "method": "GET", "path": "/sessions/$.session_id", "body_template": null },
    "Hippocampus:read_summaries": { "organ_url_key": "hippocampusUrl", "method": "GET", "path": "/sessions/$.session_id/summaries", "body_template": null },
    "Syntra:search":  { "organ_url_key": "syntraUrl",      "method": "POST", "path": "/search",           "body_template": { "query": "$.description", "limit": 10 } },
