    "Graph:get_concept": { "organ_url_key": "graphUrl",    "method": "GET",  "path": "/concepts/$.urn",   "body_template": null },
    "Graph:list_bindings": { "organ_url_key": "graphUrl",  "method": "POST", "path": "/query",            "body_template": { "sql": "SELECT * FROM class_bindings WHERE json_extract(data, '$.from_urn') = '$.urn' OR json_extract(data, '$.to_urn') = '$.urn' LIMIT 50" } },
    "Engram:read":    { "organ_url_key": "engramUrl",      "method": "GET",  "path": "/documents/$.urn",  "body_template": null },
    "Engram:query":   { "organ_url_key": "engramUrl",      "method": "POST", "path": "/query",            "body_template": { "query": "$.description" } },
    "Vectr:query":    { "organ_url_key": "vectrUrl",       "method": "POST", "path": "/query",            "body_template": { "query": "$.description" } },
    "Vigil:status":   { "organ_url_key": "vigilUrl",       "method": "GET",  "path": "/status",           "body_template": null },
    "Vigil:query":    { "organ_url_key": "vigilUrl",       "method": "GET",  "path": "/query",            "body_template": null },
    "SafeVault:status": { "organ_url_key": "safevaultUrl", "method": "GET",  "path": "/status",           "body_template": null },
    "SafeVault:list_destinations": { "organ_url_key": "safevaultUrl", "method": "GET", "path": "/destinations", "body_template": null },
    "Sourcegraph:search": { "organ_url_key": "sourcegraphUrl", "method": "POST", "path": "/search",       "body_template": { "query": "$.description" } },
    "Sourcegraph:read_file": { "organ_url_key": "sourcegraphUrl", "method": "GET", "path": "/files/$.urn", "body_template": null },
    "Soul:get_persona": { "organ_url_key": "soulUrl",     "method": "GET",  "path": "/personas/$.urn",   "body_template": null },
